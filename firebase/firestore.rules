rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function isString(value) {
      return value is string;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function validAssetType(type) {
      return type in ['stock', 'crypto', 'gold', 'oil'];
    }

    function validCurrency(currency) {
      return currency in ['VND', 'USD'];
    }

    function validAvatar(avatar) {
      return avatar in [
        'compass',
        'trend-up',
        'briefcase',
        'rocket',
        'shield',
        'wallet',
        'gem',
        'landmark',
      ];
    }

    function validPortfolioItem() {
      return hasOnlyKeys([
          'id',
          'symbol',
          'name',
          'type',
          'currency',
          'purchaseLots',
          'dividends',
          'quantity',
          'avgBuyPrice',
          'notes',
          'addedAt',
          'updatedAt',
        ]) &&
        isString(request.resource.data.id) &&
        isString(request.resource.data.symbol) &&
        isString(request.resource.data.name) &&
        validAssetType(request.resource.data.type) &&
        validCurrency(request.resource.data.currency) &&
        request.resource.data.purchaseLots is list &&
        request.resource.data.purchaseLots.size() > 0 &&
        request.resource.data.purchaseLots.size() <= 200 &&
        request.resource.data.dividends is list &&
        request.resource.data.dividends.size() <= 200 &&
        isNumber(request.resource.data.quantity) &&
        isNumber(request.resource.data.avgBuyPrice) &&
        (!request.resource.data.keys().hasAny(['notes']) || isString(request.resource.data.notes)) &&
        isString(request.resource.data.addedAt) &&
        isString(request.resource.data.updatedAt);
    }

    function validWatchlistItem() {
      return hasOnlyKeys(['id', 'symbol', 'name', 'type', 'addedAt']) &&
        isString(request.resource.data.id) &&
        isString(request.resource.data.symbol) &&
        isString(request.resource.data.name) &&
        validAssetType(request.resource.data.type) &&
        isString(request.resource.data.addedAt);
    }

    function validPreferences() {
      return hasOnlyKeys([
          'theme',
          'fontFamily',
          'miniChartPeriod',
          'menuOrder',
          'hiddenMenuItems',
          'displayName',
          'avatar',
          'updatedAt',
        ]) &&
        request.resource.data.theme in ['light', 'dark'] &&
        request.resource.data.fontFamily in ['editorial', 'sans', 'display'] &&
        request.resource.data.miniChartPeriod in ['1', '7', '30'] &&
        request.resource.data.menuOrder is list &&
        request.resource.data.hiddenMenuItems is list &&
        request.resource.data.displayName is string &&
        validAvatar(request.resource.data.avatar) &&
        request.resource.data.updatedAt is string;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /portfolio/{itemId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validPortfolioItem();
        allow delete: if isOwner(userId);
      }

      match /watchlist/{itemId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validWatchlistItem();
        allow delete: if isOwner(userId);
      }

      match /settings/preferences {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validPreferences();
        allow delete: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

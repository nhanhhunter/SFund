9:26:10 AM [express] GET /api/news/intl-finance 304 in 967ms :: [{"id":"http://vietstock.vn/2026/03/gia-vang-the-gioi-giam-hon-1-759-1409969.htm","title":"Giá vàng thế giới giảm hơn 1%","summary":"Giá vàng giảm hơn 1% trong phiên ngày 09/03 khi đồng USD mạnh lên và kỳ vọng lãi suất tăng cao hơn, trong bối cảnh xung đột tại Trung Đông làm gia tăng lo ngại về lạm phát.","url":"http://vietstock.vn/2026/03/gia-vang-the-gioi-giam-hon-1-759-1409969.htm","source":"Vietstock","publishedAt":"2026-03-10T01:12:38.000Z","imageUrl":"https://image.vietstock.vn/2026/03/10/gia-vang-123132_79838.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/xung-dot-o-iran-gay-gian-doan-nguon-cung-dau-lon-nhat-trong-lich-su-34-1409956.htm","title":"Xung đột ở Iran gây gián đoạn nguồn cung dầu lớn nhất trong lịch sử","summary":"Cuộc chiến giữa Mỹ với Iran đã gây ra sự gián đoạn nguồn cung dầu lớn nhất trong lịch sử, lớn hơn gấp đôi kỷ lục trước đó từng xảy ra trong cuộc khủng hoảng Trung Đông những năm 1950, theo phân tích của công ty tư vấn năng lượng Rapidan Energy.","url":"http://vietstock.vn/2026/03/xung-dot-o-iran-gay-gian-doan-nguon-cung-dau-lon-nhat-trong-lich-su-34-1409956.htm","source":"Vietstock","publishedAt":"2026-03-10T01:02:00.000Z","imageUrl":"https://image.vietstock.vn/2026/03/09/gia-dau-iran_2115471.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/chuyen-gia-thi-truong-nang-luong-doi-mat-nguy-co-khung-hoang-chua-tung-co-34-1409955.htm","title":"Chuyên gia: Thị trường năng lượng đối mặt nguy cơ khủng hoảng chưa từng có","summary":"Ngày 09/03, các nhà phân tích cảnh báo mức tăng mạnh hiện tại của giá dầu là chưa từng có. Nguyên nhân đến từ cuộc xung đột tại Trung Đông đang khiến thị trường lo ngại về việc đóng cửa kéo dài các mỏ dầu. Đặc biệt, hoạt động vận chuyển qua eo biển Hormuz - tuyến đường hàng hải c","url":"http://vietstock.vn/2026/03/chuyen-gia-thi-truong-nang-luong-doi-mat-nguy-co-khung-hoang-chua-tung-co-34-1409955.htm","source":"Vietstock","publishedAt":"2026-03-09T14:53:18.000Z","imageUrl":"https://image.vietstock.vn/2026/03/09/gia-dau12121212_2045720.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/nhom-g7-thao-luan-kha-nang-xa-kho-du-tru-dau-khan-cap-my-can-nhac-xa-toi-400-trieu-thung-34-1409833.htm","title":"Nhóm G7 thảo luận khả năng xả kho dự trữ dầu khẩn cấp, Mỹ cân nhắc xả tới 400 triệu thùng","summary":"Các bộ trưởng tài chính G7 sẽ thảo luận khả năng phối hợp xả dầu từ các kho dự trữ do Cơ quan Năng lượng Quốc tế (IEA) điều phối trong một cuộc họp khẩn trong ngày 09/03 nhằm ứng phó với đà tăng mạnh của giá dầu sau xung đột tại vùng Vịnh.","url":"http://vietstock.vn/2026/03/nhom-g7-thao-luan-kha-nang-xa-kho-du-tru-dau-khan-cap-my-can-nhac-xa-toi-400-trieu-thung-34-1409833.htm","source":"Vietstock","publishedAt":"2026-03-09T08:39:55.000Z","imageUrl":"https://image.vietstock.vn/2026/03/09/gia-dau-9-3_1437393.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/gia-dau-wti-tang-soc-hon-27-len-115-usdthung-34-1409673.htm","title":"Giá dầu WTI tăng sốc hơn 27% lên 115 USD/thùng","summary":"Giá dầu thô tăng vọt 115 USD/thùng trong ngày 09/03 sau khi các nhà sản xuất lớn tại Trung Đông cắt giảm sản lượng, trong bối cảnh Eo biển Hormuz — tuyến vận tải năng lượng quan trọng — vẫn đóng cửa do cuộc chiến với Iran.","url":"http://vietstock.vn/2026/03/gia-dau-wti-tang-soc-hon-27-len-115-usdthung-34-1409673.htm","source":"Vietstock","publishedAt":"2026-03-09T04:01:14.000Z","imageUrl":"https://image.vietstock.vn/2026/03/09/oil-gia-dau_958836.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/dong-usd-cham-muc-cao-nhat-trong-ba-thang-qua-772-1409621.htm","title":"Đồng USD chạm mức cao nhất trong ba tháng qua","summary":"Chứng khoán giảm, giá dầu vượt 100 USD/thùng, đồng USD đạt đỉnh trong vòng 3 tháng, phản ánh tác động của xung đột tại Trung Đông lên kinh tế toàn cầu.","url":"http://vietstock.vn/2026/03/dong-usd-cham-muc-cao-nhat-trong-ba-thang-qua-772-1409621.htm","source":"Vietstock","publishedAt":"2026-03-09T01:41:00.000Z","imageUrl":"https://image.vietstock.vn/2026/03/09/dong-usd-tiep-tuc-tang_828347.jpg","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/kuwait-tuyen-bo-bat-kha-khang-cat-giam-san-luong-dau-do-xung-dot-trung-dong-34-1409569.htm","title":"Kuwait tuyên bố bất khả kháng, cắt giảm sản lượng dầu do xung đột Trung Đông","summary":"Tập đoàn Dầu khí Kuwait (KPC) đã bắt đầu cắt giảm sản lượng dầu vào ngày 07/03 và tuyên bố tình trạng bất khả kháng, trong bối cảnh cuộc chiến Mỹ - Iran khiến hoạt động vận chuyển năng lượng từ Trung Đông bị gián đoạn sang ngày thứ 8 liên tiếp.","url":"http://vietstock.vn/2026/03/kuwait-tuyen-bo-bat-kha-khang-cat-giam-san-luong-dau-do-xung-dot-trung-dong-34-1409569.htm","source":"Vietstock","publishedAt":"2026-03-08T06:22:43.000Z","imageUrl":"https://image.vietstock.vn/2026/03/08/kuwait_1219852.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/qatar-cac-nuoc-vung-vinh-co-the-dung-xuat-khau-nang-luong-vi-chien-tranh-gia-dau-co-the-len-150-usdthung-34-1409547.htm","title":"Qatar: Các nước Vùng Vịnh có thể dừng xuất khẩu năng lượng vì chiến tranh, giá dầu có thể lên 150 USD/thùng","summary":"Bộ trưởng Năng lượng Qatar cảnh báo rằng chiến tranh tại Trung Đông có thể “làm sụp đổ các nền kinh tế trên thế giới”, đồng thời dự báo các nước xuất khẩu năng lượng tại Vùng Vịnh có thể phải dừng sản xuất chỉ trong vài ngày và đẩy giá dầu lên 150 USD/thùng.","url":"http://vietstock.vn/2026/03/qatar-cac-nuoc-vung-vinh-co-the-dung-xuat-khau-nang-luong-vi-chien-tranh-gia-dau-co-the-len-150-usdthung-34-1409547.htm","source":"Vietstock","publishedAt":"2026-03-07T09:19:20.000Z","imageUrl":"https://image.vietstock.vn/2026/03/07/gia-dau21_1516675.png","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/hai-quan-va-bao-hiem-hang-hai-nhung-bieu-tuong-suc-manh-cua-cac-cuong-quoc-bien-772-1408991.htm","title":"Hải quân và bảo hiểm hàng hải, những biểu tượng sức mạnh của các cường quốc biển","summary":"Trong khi cả thế giới nín thở theo dõi từng diễn biến tại eo biển Hormuz, tổng thống Donald Trump đã đưa ra một tuyên bố rõ ràng và dứt khoát trên nền tảng Truth Social vào ngày 3/3/2026, khẳng định Mỹ sẽ sử dụng sức mạnh hải quân và tài chính để bảo vệ dòng chảy năng lượng toàn ","url":"http://vietstock.vn/2026/03/hai-quan-va-bao-hiem-hang-hai-nhung-bieu-tuong-suc-manh-cua-cac-cuong-quoc-bien-772-1408991.htm","source":"Vietstock","publishedAt":"2026-03-07T03:02:00.000Z","imageUrl":"https://image.vietstock.vn/2026/03/06/hormuz-1772526208-5740-1772526486_913205.jpg","sentiment":"Neutral","topics":[]},{"id":"http://vietstock.vn/2026/03/gia-vang-tang-manh-len-gan-5160-usd-sau-bao-cao-viec-lam-my-759-1409500.htm","title":"Giá vàng tăng mạnh lên gần 5,160 USD sau báo cáo việc làm Mỹ","summary":"Giá vàng tăng trong ngày 06/03 sau khi dữ liệu việc làm Mỹ yếu hơn kỳ vọng duy trì hy vọng Cục Dự trữ Liên bang Mỹ (Fed) sẽ cắt giảm lãi suất, tuy nhiên kim loại quý này vẫn đang trên đà ghi nhận tuần giảm đầu tiên trong năm tuần do đồng USD mạnh lên hạn chế đà tăng.","url":"http://vietstock.vn/2026/03/gia-vang-tang-manh-len-gan-5160-usd-sau-bao-cao-viec-lam-my-759-1409500.htm","source":"Vietstock","publishedAt":"2026-03-07T01:05:25.000Z","imageUrl":"https://image.vietstock.vn/2026/03/07/gold-213312_72786.png","sentiment":"Neutral","topics":[]}]
